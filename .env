# Environment file for docker-compose and local runs
# Values here are used by docker-compose.yml and by the Spring Boot app (via application.yml)

# Database host: when running compose, keep as 'db' so services can resolve it; when running the app on the host, set this to 'localhost'
DB_HOST=db
DB_PORT=5432
DB_NAME=investigation_db
DB_USER=postgres
DB_PASS=postgres

# Optional: application port (application.yml defaults to 8080)
APP_PORT=8080

# Optional: Postgres image tag used by compose (if you change compose to use it)
POSTGRES_IMAGE=postgres:15

# Optional: Spring profile (if you support profiles)
SPRING_PROFILES_ACTIVE=local
